# Copy to .env and fill in values. Compose reads .env at the repo root.

# --- AI ---
# Anthropic Claude API key — required for advisory, chat, article personalization, chart narrative.
ANTHROPIC_API_KEY=

# Model selection — pinned in BRD/plan. Override only if your account doesn't have access.
CLAUDE_ADVISORY_MODEL=claude-opus-4-6
CLAUDE_PERSONALIZATION_MODEL=claude-sonnet-4-6
CLAUDE_CHAT_MODEL=claude-opus-4-6

# --- Live data providers (all free tier) ---
# Optional: bumps yfinance fallback quality.
ALPHA_VANTAGE_API_KEY=
# Optional: FRED macro data — works without a key for many series but unauthenticated rate-limits are tighter.
FRED_API_KEY=

# --- Backend runtime ---
REDIS_URL=redis://redis:6379/0
PRICE_CACHE_TTL_SECONDS=300
NEWS_CACHE_TTL_SECONDS=900
MACRO_CACHE_TTL_SECONDS=3600
PERSONALIZATION_CACHE_TTL_SECONDS=86400

# --- Frontend ---
NEXT_PUBLIC_API_BASE=/api
